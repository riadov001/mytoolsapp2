# ─────────────────────────────────────────────
# MyTools — Environment Variables Reference
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────

# ── External Backend ──────────────────────────
EXPO_PUBLIC_EXTERNAL_API_URL=https://app-backend.mytoolsgroup.eu
EXPO_PUBLIC_EXTERNAL_API_FALLBACK_URL=https://mytoolsapp-backend.mytoolsgroup.eu
EXTERNAL_API_URL=https://app-backend.mytoolsgroup.eu/api
EXTERNAL_API_FALLBACK_URL=https://mytoolsapp-backend.mytoolsgroup.eu/api

# ── Firebase (client-side, all public) ───────
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ── Google Auth ───────────────────────────────
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# ── Firebase Admin SDK (server-side secret) ───
# Set this as a Replit Secret, never in a file
# FIREBASE_SERVICE_ACCOUNT_KEY=<json content>

# ── Server ────────────────────────────────────
PORT=8081
SESSION_SECRET=
