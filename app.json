{
  "expo": {
    "name": "Myt",
    "slug": "myt",
    "version": "2.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/logo_new.png",
    "scheme": "myt",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/logo_new.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.mytoolsmobile.mytoolsgroup.eu",
      "buildNumber": "14",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "MyTools Admin utilise l'appareil photo pour photographier les véhicules et pièces dans le cadre des devis.",
        "NSPhotoLibraryUsageDescription": "MyTools Admin accède à la galerie pour joindre des photos aux devis et demandes de service.",
        "NSPhotoLibraryAddUsageDescription": "MyTools Admin peut enregistrer des photos dans votre bibliothèque.",
        "NSCalendarsUsageDescription": "MyTools synchronise vos rendez-vous avec votre calendrier natif.",
        "ITSAppUsesNonExemptEncryption": "NO",
        "NSUserNotificationsUsageDescription": "MyTools vous envoie des notifications pour les mises à jour de devis, nouvelles factures et rappels de rendez-vous.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.129808585113-q81uhog8n2eivfpgg924tdfrh3s3ifau"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.myt.app",
      "versionCode": 2,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/images/logo_new.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/logo_new.png"
    },
    "privacyPolicyUrl": "https://www.mytoolsgroup.eu/privacy",
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#DC2626",
          "sounds": []
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "MyTools Admin utilise l'appareil photo pour photographier les véhicules et pièces lors des devis."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MyTools Admin accède à la galerie pour joindre des photos aux devis et demandes de service."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "238951c8-0adb-4aab-8736-c0da7bbf9e96"
      },
      "router": {}
    },
    "owner": "myjantes"
  }
}
